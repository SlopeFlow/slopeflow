//@version=6
indicator("BOS Reversal | Newsie", overlay=true, max_bars_back=1000)
bos_n = input.int(30, "BOS Lookback bars", group="Setup")
ml = input.float(50.0, "Min leg pts", group="Setup")
stp = input.float(30.0, "Stop pts", group="Risk")
tp = input.float(60.0, "TP pts", group="Risk")
cd = input.int(60, "Cooldown bars", group="Setup")
ll = input.int(100, "Line length", group="Display")
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb = t23 or t29 or t35
tz = t23 ? "23" : t29 ? "29" : "35"
bc = close > open
br = close < open
prior_high = ta.highest(high, bos_n)
prior_low  = ta.lowest(low,  bos_n)
bull_bos = close > prior_high[1] and bc
bear_bos = close < prior_low[1]  and br
var string bos_dir = na
var float  bos_ext = na
var int    bos_bar = -999
var int    last_sig = -999
var float  leg_hi_track = na
var float  leg_lo_track = na
if bull_bos
    bos_dir := "bull"
    bos_ext := prior_low[1]
    bos_bar := bar_index
    leg_hi_track := high
    leg_lo_track := bos_ext
if bear_bos
    bos_dir := "bear"
    bos_ext := prior_high[1]
    bos_bar := bar_index
    leg_hi_track := bos_ext
    leg_lo_track := low
if bos_dir == "bull" and not bull_bos
    leg_hi_track := math.max(leg_hi_track, high)
if bos_dir == "bear" and not bear_bos
    leg_lo_track := math.min(leg_lo_track, low)
leg_size = leg_hi_track - leg_lo_track
z40 = leg_lo_track + leg_size * 0.40
z50 = leg_lo_track + leg_size * 0.50
z60 = leg_lo_track + leg_size * 0.60
plot(not na(bos_dir) ? leg_hi_track : na, "Leg Hi", color=color.new(color.lime, 60), linewidth=1, style=plot.style_stepline)
plot(not na(bos_dir) ? leg_lo_track : na, "Leg Lo", color=color.new(color.red, 60), linewidth=1, style=plot.style_stepline)
plot(not na(bos_dir) ? z50 : na, "50%", color=color.new(color.yellow, 0), linewidth=2)
plot(not na(bos_dir) ? z40 : na, "40%", color=color.new(color.white, 70), linewidth=1)
plot(not na(bos_dir) ? z60 : na, "60%", color=color.new(color.white, 70), linewidth=1)
bgcolor(tb ? color.new(color.purple, 93) : na)
age_ok = bar_index - bos_bar > 15
cd_ok  = bar_index - last_sig > cd
size_ok = leg_size >= ml
in_zone_l = low  <= z60 and low  >= z40
in_zone_s = high >= z40 and high <= z60
ls = tb and bos_dir == "bull" and in_zone_l and bc and age_ok and cd_ok and size_ok
ss = tb and bos_dir == "bear" and in_zone_s and br and age_ok and cd_ok and size_ok
if ls or ss
    last_sig := bar_index
plotshape(bull_bos, "Bull BOS", shape.triangleup,   location.belowbar, color=color.new(color.orange, 30), size=size.tiny)
plotshape(bear_bos, "Bear BOS", shape.triangledown,  location.abovebar, color=color.new(color.orange, 30), size=size.tiny)
plotshape(ls, "Long", shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(ss, "Short", shape.triangledown, location.abovebar, color=color.new(color.red, 0), size=size.normal)
var line t1 = na
var line sl = na
atr = ta.atr(14)
if ls
    line.delete(t1)
    line.delete(sl)
    t1 := line.new(bar_index, close+tp,  bar_index+ll, close+tp,  color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    sl := line.new(bar_index, close-stp, bar_index+ll, close-stp, color=color.new(color.red, 20), width=1, style=line.style_dashed)
    label.new(bar_index, low-atr*0.5, "L"+tz, style=label.style_label_up, color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
if ss
    line.delete(t1)
    line.delete(sl)
    t1 := line.new(bar_index, close-tp,  bar_index+ll, close-tp,  color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    sl := line.new(bar_index, close+stp, bar_index+ll, close+stp, color=color.new(color.red, 20), width=1, style=line.style_dashed)
    label.new(bar_index, high+atr*0.5, "S"+tz, style=label.style_label_down, color=color.new(color.red, 5), textcolor=color.white, size=size.small)
alertcondition(ls, "BOS LONG",  "BOS Reversal: LONG")
alertcondition(ss, "BOS SHORT", "BOS Reversal: SHORT")
