//@version=6
indicator("9-10 Range v4 | Newsie", overlay=true, max_bars_back=1000)

// ── Inputs ───────────────────────────────────────────────────────────────────
use_tb     = input.bool(true,              "Use 23/29/35 filter",  group="Setup")
box_color  = input.color(color.new(color.yellow, 80), "Range box color", group="Display")
box_border = input.color(color.new(color.yellow, 20), "Box border color", group="Display")

// ── Time helpers ─────────────────────────────────────────────────────────────
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
et_mins = eh * 60 + em

// ── Time bar detection ───────────────────────────────────────────────────────
s   = eh + em
d   = em - eh
t23 = (s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4)
t29 = (s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9)
t35 = (s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6)
tb  = t23 or t29 or t35
tz  = t23 ? "23" : t29 ? "29" : t35 ? "35" : ""

// ── 9-10am range tracking ────────────────────────────────────────────────────
in_range_window = et_mins >= 540 and et_mins < 600  // 9:00-9:59 ET
in_trade_window = et_mins >= 600 and et_mins < 900  // 10:00-14:59 ET

var float range_hi   = na
var float range_lo   = na
var int   range_start = na
var int   range_end   = na
var bool  range_set   = false
var bool  bull_break  = false
var bool  bear_break  = false
var box   range_box   = na

// Build range during 9-10am window
is_9am_open = et_mins == 540 and et_mins[1] != 540
if is_9am_open
    range_hi    := high
    range_lo    := low
    range_start := bar_index
    range_set   := false
    bull_break  := false
    bear_break  := false

if in_range_window and not na(range_hi)
    range_hi := math.max(range_hi, high)
    range_lo := math.min(range_lo, low)

// Mark end of range at 10am
is_10am = et_mins == 600 and et_mins[1] != 600
if is_10am and not na(range_hi)
    range_end := bar_index
    range_set := true
    box.delete(range_box)
    range_box := box.new(range_start, range_hi, range_end + 480, range_lo,
                         border_color=box_border, border_width=1,
                         bgcolor=box_color, extend=extend.right)
    // 50% dashed line inside box
    line.new(range_start, range_lo + (range_hi - range_lo) * 0.5,
             range_end + 480, range_lo + (range_hi - range_lo) * 0.5,
             color=box_border, style=line.style_dashed, width=1, extend=extend.right)

// ── ATR for label offset ─────────────────────────────────────────────────────
atr = ta.atr(14)

// ── Hourly close breakout detection (10am-3pm) ───────────────────────────────
is_hourly_close = em == 0  // top of each hour
in_hourly_window = et_mins >= 600 and et_mins < 900

if range_set and is_hourly_close and in_hourly_window
    if close > range_hi and not bull_break
        bull_break := true
        bear_break := false
        label.new(bar_index, high + atr * 0.5, "B↑", style=label.style_label_down, color=color.new(color.lime, 0), textcolor=color.black, size=size.small)
    if close < range_lo and not bear_break
        bear_break := true
        bull_break := false
        label.new(bar_index, low - atr * 0.5, "B↓", style=label.style_label_up, color=color.new(color.red, 0), textcolor=color.white, size=size.small)

// ── 40-60% retest zone ───────────────────────────────────────────────────────
rng  = not na(range_hi) ? range_hi - range_lo : na
z40  = not na(rng) ? range_lo + rng * 0.40 : na
z50  = not na(rng) ? range_lo + rng * 0.50 : na
z60  = not na(rng) ? range_lo + rng * 0.60 : na

// ── Retest signal ─────────────────────────────────────────────────────────────
tb_ok   = not use_tb or tb
in_zone = not na(z40) and high >= z40 and low <= z60

retest_long  = bull_break and in_zone and tb_ok and in_trade_window
retest_short = bear_break and in_zone and tb_ok and in_trade_window

plotshape(retest_long,  "Retest Long",  shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(retest_short, "Retest Short", shape.triangledown, location.abovebar, color=color.new(color.red,  0), size=size.normal)

if retest_long
    label.new(bar_index, low-atr*0.5, use_tb ? tz : "R", style=label.style_label_up,   color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
if retest_short
    label.new(bar_index, high+atr*0.5, use_tb ? tz : "R", style=label.style_label_down, color=color.new(color.red,  5), textcolor=color.white, size=size.small)

alertcondition(retest_long,  "9-10 Retest Long",  "9-10 Range: Retest Long")
alertcondition(retest_short, "9-10 Retest Short", "9-10 Range: Retest Short")
