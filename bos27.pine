//@version=6
indicator("BOS Reversal v27 | Newsie", overlay=true, max_bars_back=1000)
bos_n  = input.int(60,    "BOS Lookback",        group="Setup")
ml     = input.float(70.0,"Min leg pts",         group="Setup")
stp    = input.float(30.0,"Stop pts",            group="Risk")
tp     = input.float(60.0,"TP pts",              group="Risk")
cd     = input.int(45,    "Cooldown bars",       group="Setup")
use_t  = input.bool(true, "Use 23/29/35 filter", group="Setup")
ll     = input.int(100,   "Line length",         group="Display")
bc = close > open
br = close < open
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb  = not use_t or (t23 or t29 or t35)
tz  = t23 ? "23" : t29 ? "29" : t35 ? "35" : "??"
ph = ta.highest(high, bos_n)
pl = ta.lowest(low,  bos_n)
bull_bos = bc and close > ph[1]
bear_bos = br and close < pl[1]
var bool  bull_active = false
var bool  bear_active = false
var float leg_hi = na
var float leg_lo = na
var int   bos_bar = -999
var int   last_sig = -999
// Store actual bar index of swing endpoints
var int   swing_hi_bar = na
var int   swing_lo_bar = na
if bull_bos
    bull_active := true
    bear_active := false
    leg_hi := high
    leg_lo := pl[1]
    bos_bar := bar_index
    swing_hi_bar := bar_index
    // Find the bar where pl[1] occurred
    swing_lo_bar := bar_index + int(ta.lowestbars(low, bos_n))
if bear_bos
    bear_active := true
    bull_active := false
    leg_hi := ph[1]
    leg_lo := low
    bos_bar := bar_index
    swing_lo_bar := bar_index
    // Find the bar where ph[1] occurred
    swing_hi_bar := bar_index + int(ta.highestbars(high, bos_n))
if bull_active and not bull_bos
    if high > leg_hi
        leg_hi := high
        bos_bar := bar_index
        swing_hi_bar := bar_index
if bear_active and not bear_bos
    if low < leg_lo
        leg_lo := low
        bos_bar := bar_index
        swing_lo_bar := bar_index
lsz = leg_hi - leg_lo
z40 = leg_lo + lsz * 0.40
z60 = leg_lo + lsz * 0.60
bgcolor(tb and use_t ? color.new(color.purple, 93) : na)
age_ok  = bar_index - bos_bar > 3
cd_ok   = bar_index - last_sig > cd
size_ok = lsz >= ml
in_l = low  <= z60 and low  >= z40
in_s = high >= z40 and high <= z60
ls = tb and bull_active and in_l and bc and age_ok and cd_ok and size_ok
ss = tb and bear_active and in_s and br and age_ok and cd_ok and size_ok
if ls or ss
    last_sig := bar_index
// Time bar at each endpoint
lo_off = int(ta.lowestbars(low, bos_n))
hi_off = int(ta.highestbars(high, bos_n))
tz_lo  = t23[math.abs(lo_off)] ? "23" : t29[math.abs(lo_off)] ? "29" : t35[math.abs(lo_off)] ? "35" : "o"
tz_hi  = t23[math.abs(hi_off)] ? "23" : t29[math.abs(hi_off)] ? "29" : t35[math.abs(hi_off)] ? "35" : "o"
var label hi_lbl = na
var label lo_lbl = na
if bull_bos
    label.delete(hi_lbl)
    label.delete(lo_lbl)
    hi_lbl := label.new(swing_hi_bar, leg_hi, tb ? tz : "o",  style=label.style_label_down, color=color.new(color.red,  0), textcolor=color.white, size=size.tiny)
    lo_lbl := label.new(swing_lo_bar, leg_lo, tz_lo,           style=label.style_label_up,   color=color.new(color.lime, 0), textcolor=color.black, size=size.tiny)
if bear_bos
    label.delete(hi_lbl)
    label.delete(lo_lbl)
    hi_lbl := label.new(swing_hi_bar, leg_hi, tz_hi,           style=label.style_label_down, color=color.new(color.red,  0), textcolor=color.white, size=size.tiny)
    lo_lbl := label.new(swing_lo_bar, leg_lo, tb ? tz : "o",  style=label.style_label_up,   color=color.new(color.lime, 0), textcolor=color.black, size=size.tiny)
// Update dot position when leg extends
if bull_active and not bull_bos and high == leg_hi
    label.delete(hi_lbl)
    hi_lbl := label.new(swing_hi_bar, leg_hi, tb ? tz : "o", style=label.style_label_down, color=color.new(color.red, 0), textcolor=color.white, size=size.tiny)
if bear_active and not bear_bos and low == leg_lo
    label.delete(lo_lbl)
    lo_lbl := label.new(swing_lo_bar, leg_lo, tb ? tz : "o", style=label.style_label_up, color=color.new(color.lime, 0), textcolor=color.black, size=size.tiny)
plotshape(ls, "Long",  shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(ss, "Short", shape.triangledown, location.abovebar, color=color.new(color.red,  0), size=size.normal)
var line t1 = na
var line sl = na
atr = ta.atr(14)
if ls
    line.delete(t1)
    line.delete(sl)
    t1 := line.new(bar_index, close+tp,  bar_index+ll, close+tp,  color=color.new(color.lime, 0), width=2)
    sl := line.new(bar_index, close-stp, bar_index+ll, close-stp, color=color.new(color.red, 20), width=1)
    label.new(bar_index, low-atr*0.5, "L"+tz, style=label.style_label_up, color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
if ss
    line.delete(t1)
    line.delete(sl)
    t1 := line.new(bar_index, close-tp,  bar_index+ll, close-tp,  color=color.new(color.lime, 0), width=2)
    sl := line.new(bar_index, close+stp, bar_index+ll, close+stp, color=color.new(color.red, 20), width=1)
    label.new(bar_index, high+atr*0.5, "S"+tz, style=label.style_label_down, color=color.new(color.red, 5), textcolor=color.white, size=size.small)
alertcondition(ls, "BOS LONG",  "BOS LONG")
alertcondition(ss, "BOS SHORT", "BOS SHORT")
