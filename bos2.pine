//@version=6
strategy("BOS Reversal BT v2 | Newsie", overlay=true, max_bars_back=1000, initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_contract, commission_value=2.05, slippage=1)
bos_n = input.int(30, "BOS Lookback bars", group="Setup")
ml = input.float(50.0, "Min leg pts", group="Setup")
stp = input.float(30.0, "Stop pts", group="Risk")
tp = input.float(60.0, "TP pts", group="Risk")
cd = input.int(60, "Cooldown bars", group="Setup")
use_time = input.bool(true, "Use 23/29/35 filter", group="Setup")
bc = close > open
br = close < open
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb = not use_time or (t23 or t29 or t35)
prior_high = ta.highest(high, bos_n)
prior_low  = ta.lowest(low,  bos_n)
bull_bos = close > prior_high[1] and bc
bear_bos = close < prior_low[1]  and br
var string bos_dir = na
var float  bos_ext = na
var int    bos_bar = -999
var int    last_sig = -999
var float  leg_hi_track = na
var float  leg_lo_track = na
if bull_bos
    bos_dir := "bull"
    bos_ext := prior_low[1]
    bos_bar := bar_index
    leg_hi_track := high
    leg_lo_track := bos_ext
if bear_bos
    bos_dir := "bear"
    bos_ext := prior_high[1]
    bos_bar := bar_index
    leg_hi_track := bos_ext
    leg_lo_track := low
if bos_dir == "bull" and not bull_bos
    leg_hi_track := math.max(leg_hi_track, high)
if bos_dir == "bear" and not bear_bos
    leg_lo_track := math.min(leg_lo_track, low)
leg_size = leg_hi_track - leg_lo_track
z40 = leg_lo_track + leg_size * 0.40
z60 = leg_lo_track + leg_size * 0.60
z50 = (z40 + z60) / 2
plot(not na(bos_dir) ? leg_hi_track : na, "Leg Hi", color=color.new(color.lime, 60), linewidth=1, style=plot.style_stepline)
plot(not na(bos_dir) ? leg_lo_track : na, "Leg Lo", color=color.new(color.red, 60), linewidth=1, style=plot.style_stepline)
plot(not na(bos_dir) ? z50 : na, "50%", color=color.new(color.yellow, 0), linewidth=1)
bgcolor(tb and use_time ? color.new(color.purple, 93) : na)
age_ok = bar_index - bos_bar > 3
cd_ok  = bar_index - last_sig > cd
size_ok = leg_size >= ml
in_zone_l = low  <= z60 and low  >= z40
in_zone_s = high >= z40 and high <= z60
ls = tb and bos_dir == "bull" and in_zone_l and bc and age_ok and cd_ok and size_ok and strategy.position_size == 0
ss = tb and bos_dir == "bear" and in_zone_s and br and age_ok and cd_ok and size_ok and strategy.position_size == 0
if ls or ss
    last_sig := bar_index
plotshape(ls, "L", shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.small)
plotshape(ss, "S", shape.triangledown,  location.abovebar, color=color.new(color.red, 0), size=size.small)
if ls
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", limit=close+tp, stop=close-stp)
if ss
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", limit=close-tp, stop=close+stp)
