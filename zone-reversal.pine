//@version=6
indicator("Zone Reversal v8 | Newsie", overlay=true, max_bars_back=1000)
stp = input.float(30.0, "Stop pts", group="R")
tp = input.float(60.0, "TP pts", group="R")
be = input.float(30.0, "BE at pts", group="R")
ml = input.float(70.0, "Min leg pts", group="S")
sw = input.int(15, "Swing bars", group="S")
cd = input.int(60, "Cooldown bars", group="S")
ma = input.int(15, "Min leg age bars", group="S")
ll = input.int(150, "Line length", group="D")
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb = t23 or t29 or t35
tz = t23 ? "23" : t29 ? "29" : "35"
bc = close > open
br = close < open
ph = ta.pivothigh(high, sw, sw)
pl = ta.pivotlow(low, sw, sw)
vph = not na(ph) and close[sw] > open[sw]
vpl = not na(pl) and close[sw] < open[sw]
var float lh = na
var float lo = na
var float z5 = na
var bool la = false
var bool sa = false
var int last_sig = -999
var int leg_bar = -999
if timeframe.change("D")
    lh := na
    lo := na
    z5 := na
    la := false
    sa := false
if vph
    if not la or ph > lh
        if na(lo)
            lo := low[sw]
        la := true
        sa := false
    lh := ph
    if not na(lo) and lh - lo >= ml
        z5 := (lh + lo) / 2
        leg_bar := bar_index
if vpl
    if not sa or pl < lo
        if na(lh)
            lh := high[sw]
        sa := true
        la := false
    lo := pl
    if not na(lh) and lh - lo >= ml
        z5 := (lh + lo) / 2
        leg_bar := bar_index
plot(z5, "50pct", color=color.new(color.yellow, 0), linewidth=2)
plot(lh, "Hi", color=color.new(color.lime, 60), linewidth=1, style=plot.style_stepline)
plot(lo, "Lo", color=color.new(color.red, 60), linewidth=1, style=plot.style_stepline)
leg_size = not na(lh) and not na(lo) ? lh - lo : na
z40 = not na(leg_size) ? lo + leg_size * 0.40 : na
z60 = not na(leg_size) ? lo + leg_size * 0.60 : na
plot(z40, "40pct", color=color.new(color.white, 70), linewidth=1, style=plot.style_line)
plot(z60, "60pct", color=color.new(color.white, 70), linewidth=1, style=plot.style_line)
cd_ok = bar_index - last_sig > cd
in_band_l = la and not na(z40) and not na(z60) and low <= z60 and low >= z40
in_band_s = sa and not na(z40) and not na(z60) and high >= z40 and high <= z60
age_ok = bar_index - leg_bar > ma
ls = tb and in_band_l and bc and cd_ok and age_ok
ss = tb and in_band_s and br and cd_ok and age_ok
if ls or ss
    last_sig := bar_index
bgcolor(tb ? color.new(color.purple, 93) : na)
plotshape(not na(ph) and not vph, "BH", shape.xcross, location.abovebar, color=color.new(color.orange, 30), size=size.tiny)
plotshape(not na(pl) and not vpl, "BL", shape.xcross, location.belowbar, color=color.new(color.orange, 30), size=size.tiny)
plotshape(ls, "L", shape.triangleup, location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(ss, "S", shape.triangledown, location.abovebar, color=color.new(color.red, 0), size=size.normal)
var line t1 = na
var line t2 = na
var line sl = na
atr = ta.atr(14)
if ls
    line.delete(t1)
    line.delete(t2)
    line.delete(sl)
    t1 := line.new(bar_index, close+be, bar_index+ll, close+be, color=color.new(color.lime, 50), width=1, style=line.style_dotted)
    t2 := line.new(bar_index, close+tp, bar_index+ll, close+tp, color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    sl := line.new(bar_index, close-stp, bar_index+ll, close-stp, color=color.new(color.red, 20), width=1, style=line.style_dashed)
    label.new(bar_index, low-atr*0.5, "L"+tz, style=label.style_label_up, color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
if ss
    line.delete(t1)
    line.delete(t2)
    line.delete(sl)
    t1 := line.new(bar_index, close-be, bar_index+ll, close-be, color=color.new(color.lime, 50), width=1, style=line.style_dotted)
    t2 := line.new(bar_index, close-tp, bar_index+ll, close-tp, color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    sl := line.new(bar_index, close+stp, bar_index+ll, close+stp, color=color.new(color.red, 20), width=1, style=line.style_dashed)
    label.new(bar_index, high+atr*0.5, "S"+tz, style=label.style_label_down, color=color.new(color.red, 5), textcolor=color.white, size=size.small)
alertcondition(ls, "LONG", "Zone: LONG")
alertcondition(ss, "SHORT", "Zone: SHORT")
