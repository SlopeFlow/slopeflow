//@version=6
indicator("Zone Reversal v6 | Newsie", overlay=true, max_bars_back=1000)
stop_pts = input.float(10.0, "Stop pts", group="Risk")
tp1_pts = input.float(20.0, "TP1 pts", group="Risk")
tp2_pts = input.float(30.0, "TP2 pts", group="Risk")
line_len = input.int(200, "Lines", group="Display")
eth = hour(time, "America/New_York")
etm = minute(time, "America/New_York")
s = eth + etm
d = etm - eth
t23 = (s>=22 and s<=24) or (d>=22 and d<=24) or (etm>=22 and etm<=24)
t23 := t23 or (eth==2 and etm>=2 and etm<=4)
t29 = (s>=28 and s<=30) or (d>=28 and d<=30) or (etm>=28 and etm<=30)
t29 := t29 or (eth==2 and etm>=8 and etm<=9)
t35 = (s>=34 and s<=36) or (d>=34 and d<=36) or (etm>=34 and etm<=36)
t35 := t35 or (eth==3 and etm>=4 and etm<=6)
tbar = t23 or t29 or t35
tlbl = t23 ? "23" : t29 ? "29" : "35"
bc = close > open
br = close < open
var float lh = na
var float ll = na
var float z5 = na
var bool la = false
var bool sa = false
nd = ta.change(dayofmonth(time, "America/New_York")) != 0
if nd
    lh := na
    ll := na
    z5 := na
    la := false
    sa := false
nhh = bc and high > ta.highest(high[1], 5)
nll = br and low < ta.lowest(low[1], 5)
if nhh
    if not la
        ll := ta.lowest(low, 10)
        la := true
        sa := false
    lh := high
    z5 := (lh + ll) / 2
if nll
    if not sa
        lh := ta.highest(high, 10)
        sa := true
        la := false
    ll := low
    z5 := (lh + ll) / 2
plot(not na(z5) ? z5 : na, "Mid", color=color.new(color.white, 40), linewidth=1)
plot(not na(lh) ? lh : na, "Hi", color=color.new(color.lime, 50), linewidth=1, style=plot.style_stepline)
plot(not na(ll) ? ll : na, "Lo", color=color.new(color.red, 50), linewidth=1, style=plot.style_stepline)
zt = 5.0
a5l = la and not na(z5) and low<=z5+zt and low>=z5-zt
a5s = sa and not na(z5) and high>=z5-zt and high<=z5+zt
lsig = tbar and a5l and bc
ssig = tbar and a5s and br
bgcolor(tbar ? color.new(color.purple, 93) : na)
plotshape(nhh and br, "BadHi", shape.xcross, location.abovebar, color=color.new(color.orange, 20), size=size.tiny)
plotshape(nll and bc, "BadLo", shape.xcross, location.belowbar, color=color.new(color.orange, 20), size=size.tiny)
plotshape(lsig, "Long", shape.triangleup, location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(ssig, "Short", shape.triangledown, location.abovebar, color=color.new(color.red, 0), size=size.normal)
var line t1 = na
var line t2 = na
var line sl = na
atr = ta.atr(14)
if lsig
    line.delete(t1)
    line.delete(t2)
    line.delete(sl)
    t1 := line.new(bar_index, close+tp1_pts, bar_index+line_len, close+tp1_pts, color=color.new(color.lime, 40), width=1, style=line.style_dashed)
    t2 := line.new(bar_index, close+tp2_pts, bar_index+line_len, close+tp2_pts, color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    sl := line.new(bar_index, close-stop_pts, bar_index+line_len, close-stop_pts, color=color.new(color.red, 20), width=1, style=line.style_dashed)
    label.new(bar_index, low-atr*0.5, "L"+tlbl, style=label.style_label_up, color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
if ssig
    line.delete(t1)
    line.delete(t2)
    line.delete(sl)
    t1 := line.new(bar_index, close-tp1_pts, bar_index+line_len, close-tp1_pts, color=color.new(color.lime, 40), width=1, style=line.style_dashed)
    t2 := line.new(bar_index, close-tp2_pts, bar_index+line_len, close-tp2_pts, color=color.new(color.lime, 0), width=2, style=line.style_dashed)
    sl := line.new(bar_index, close+stop_pts, bar_index+line_len, close+stop_pts, color=color.new(color.red, 20), width=1, style=line.style_dashed)
    label.new(bar_index, high+atr*0.5, "S"+tlbl, style=label.style_label_down, color=color.new(color.red, 5), textcolor=color.white, size=size.small)
alertcondition(lsig, "LONG", "Zone: LONG")
alertcondition(ssig, "SHORT", "Zone: SHORT")
