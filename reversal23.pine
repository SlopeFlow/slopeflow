//@version=6
indicator("23 Sweep Reversal | Newsie", overlay=true, max_bars_back=500)

// ── Inputs ───────────────────────────────────────────────────────────────────
confirm_bars = input.int(5,  "Confirmation window", minval=1, maxval=10, group="Setup")
sweep_lookback = input.int(20, "Sweep lookback", minval=3, maxval=100, group="Setup")
cd_bars      = input.int(30, "Cooldown bars", minval=1, maxval=200, group="Setup")
ll           = input.int(100,"Line length", group="Display")

// ── Time bar detection ───────────────────────────────────────────────────────
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s  = eh + em
d  = em - eh
t23 = (s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4)

// ── Track 23 sweep candidate ─────────────────────────────────────────────────
var bool  watch_long = false
var bool  watch_short = false
var float sweep_hi = na
var float sweep_lo = na
var int   sweep_bar = na
var int   bars_left = 0

// 23 sweep candidate: takes liquidity from broader lookback to the left
prior_low  = ta.lowest(low[1], sweep_lookback)
prior_high = ta.highest(high[1], sweep_lookback)
low_sweep  = t23 and low < prior_low
high_sweep = t23 and high > prior_high

var int last_sig = -999
cd_ok = bar_index - last_sig > cd_bars

if low_sweep and cd_ok
    watch_long := true
    watch_short := false
    sweep_hi := high
    sweep_lo := low
    sweep_bar := bar_index
    bars_left := confirm_bars

if high_sweep and cd_ok
    watch_short := true
    watch_long := false
    sweep_hi := high
    sweep_lo := low
    sweep_bar := bar_index
    bars_left := confirm_bars

// countdown
if (watch_long or watch_short) and bar_index > sweep_bar
    bars_left -= 1

// confirmations within window
long_confirm  = watch_long and bar_index > sweep_bar and bars_left >= 0 and close > sweep_hi
short_confirm = watch_short and bar_index > sweep_bar and bars_left >= 0 and close < sweep_lo

// expire setup if no confirmation in time
if (watch_long or watch_short) and bars_left < 0
    watch_long := false
    watch_short := false

// ── Fixed SL/TP ──────────────────────────────────────────────────────────────
sl_pts = 10.0
tp_pts = 40.0

// ── Visuals ──────────────────────────────────────────────────────────────────
plotshape(low_sweep,  "23 Low Sweep",  shape.circle, location.belowbar, color=color.new(color.lime, 0), size=size.tiny)
plotshape(high_sweep, "23 High Sweep", shape.circle, location.abovebar, color=color.new(color.red,  0), size=size.tiny)
plotshape(long_confirm,  "Long Confirm",  shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.normal)
plotshape(short_confirm, "Short Confirm", shape.triangledown, location.abovebar, color=color.new(color.red,  0), size=size.normal)

var line tp_ln = na
var line sl_ln = na
atr = ta.atr(14)
if long_confirm
    last_sig := bar_index
    line.delete(tp_ln)
    line.delete(sl_ln)
    tp_ln := line.new(bar_index, close + tp_pts, bar_index + ll, close + tp_pts, color=color.new(color.lime, 20), width=1)
    sl_ln := line.new(bar_index, close - sl_pts, bar_index + ll, close - sl_pts, color=color.new(color.red,  20), width=1)
    label.new(bar_index, low - atr * 0.5, "23", style=label.style_label_up, color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
    watch_long := false
if short_confirm
    last_sig := bar_index
    line.delete(tp_ln)
    line.delete(sl_ln)
    tp_ln := line.new(bar_index, close - tp_pts, bar_index + ll, close - tp_pts, color=color.new(color.lime, 20), width=1)
    sl_ln := line.new(bar_index, close + sl_pts, bar_index + ll, close + sl_pts, color=color.new(color.red,  20), width=1)
    label.new(bar_index, high + atr * 0.5, "23", style=label.style_label_down, color=color.new(color.red, 5), textcolor=color.white, size=size.small)
    watch_short := false

alertcondition(long_confirm,  "23 Reversal Long",  "23 Sweep Reversal Long")
alertcondition(short_confirm, "23 Reversal Short", "23 Sweep Reversal Short")
