//@version=6
indicator("PL Zone | Newsie", overlay=true, max_bars_back=1000)
fib_tol  = input.float(5.0,  "100% tolerance pts", group="Setup")
ll       = input.int(500,    "Line length",         group="Display")
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb  = t23 or t29 or t35
tz  = t23 ? "23" : t29 ? "29" : "35"
bc  = close > open
br  = close < open
is_sess_open = eh == 18 and em == 0
var float soh = na
var float sol = na
if is_sess_open
    soh := high
    sol := low
fr    = not na(soh) ? soh - sol : na
f100u = not na(fr) ? soh + fr        : na
f110u = not na(fr) ? soh + fr * 1.1  : na
f100d = not na(fr) ? sol - fr        : na
f110d = not na(fr) ? sol - fr * 1.1  : na
f50   = not na(fr) ? (soh + sol) / 2 : na
f236  = not na(fr) ? sol + fr * 0.236: na
f618  = not na(fr) ? sol + fr * 0.618: na
f786  = not na(fr) ? sol + fr * 0.786: na
plot(not na(soh) ? soh : na, "Open High", color=color.new(#fff59d, 0),  linewidth=2, style=plot.style_stepline)
plot(not na(sol) ? sol : na, "Open Low",  color=color.new(#fff59d, 0),  linewidth=2, style=plot.style_stepline)
plot(not na(f100u) ? f100u : na, "100% Up",  color=color.new(color.red,    20), linewidth=1)
plot(not na(f110u) ? f110u : na, "110% SL",  color=color.new(color.red,    60), linewidth=1)
plot(not na(f100d) ? f100d : na, "100% Dn",  color=color.new(color.lime,   20), linewidth=1)
plot(not na(f110d) ? f110d : na, "110% SL",  color=color.new(color.lime,   60), linewidth=1)
plot(not na(f50)   ? f50   : na, "50%",      color=color.new(color.white,  40), linewidth=1)
plot(not na(f236)  ? f236  : na, "23.6%",    color=color.new(color.aqua,   40), linewidth=1)
plot(not na(f618)  ? f618  : na, "61.8%",    color=color.new(color.orange, 40), linewidth=1)
plot(not na(f786)  ? f786  : na, "78.6%",    color=color.new(color.purple, 40), linewidth=1)
bgcolor(tb ? color.new(color.purple, 93) : na)
at_100u = not na(f100u) and math.abs(high - f100u) <= fib_tol
at_100d = not na(f100d) and math.abs(low  - f100d) <= fib_tol
short_sig = tb and at_100u and bc
long_sig  = tb and at_100d and br
plotshape(short_sig, "PL Short", shape.triangledown, location.abovebar, color=color.new(color.red,  0), size=size.normal)
plotshape(long_sig,  "PL Long",  shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.normal)
var line tp1 = na
var line tp2 = na
var line sl  = na
atr = ta.atr(14)
if short_sig
    line.delete(tp1)
    line.delete(tp2)
    line.delete(sl)
    tp1 := line.new(bar_index, f50,   bar_index+ll, f50,   color=color.new(color.lime, 20), width=1)
    tp2 := line.new(bar_index, f236,  bar_index+ll, f236,  color=color.new(color.lime, 0),  width=2)
    sl  := line.new(bar_index, f110u, bar_index+ll, f110u, color=color.new(color.red,  20), width=1)
    label.new(bar_index, high+atr*0.5, "PL SHORT "+tz, style=label.style_label_down, color=color.new(color.red, 5), textcolor=color.white, size=size.small)
if long_sig
    line.delete(tp1)
    line.delete(tp2)
    line.delete(sl)
    tp1 := line.new(bar_index, f50,   bar_index+ll, f50,   color=color.new(color.lime, 20), width=1)
    tp2 := line.new(bar_index, f236,  bar_index+ll, f236,  color=color.new(color.lime, 0),  width=2)
    sl  := line.new(bar_index, f110d, bar_index+ll, f110d, color=color.new(color.red,  20), width=1)
    label.new(bar_index, low-atr*0.5, "PL LONG "+tz, style=label.style_label_up, color=color.new(color.lime, 5), textcolor=color.black, size=size.small)
alertcondition(short_sig, "PL SHORT", "PL Zone: SHORT at 100% fib")
alertcondition(long_sig,  "PL LONG",  "PL Zone: LONG at 100% fib")
