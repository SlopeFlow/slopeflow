//@version=6
indicator("23/29/35 Time Reversal 27m v2 | Newsie", overlay=true, max_bars_back=500)

// ─── INPUTS ───────────────────────────────────────────────────────────────────
lookback      = input.int(30,   "Liquidity Lookback (bars)", group="Structure")
confirm_bars  = input.int(5,    "Confirmation Window (bars)", group="Structure")
cooldown      = input.int(45,   "Cooldown (bars)",            group="Structure")
show_zones    = input.bool(true,"Highlight time bars",        group="Display")

sl_23 = input.float(20.0,  "SL — 23 bar (pts)", group="Risk per Bar")
tp_23 = input.float(50.0,  "TP — 23 bar (pts)", group="Risk per Bar")
sl_29 = input.float(30.0,  "SL — 29 bar (pts)", group="Risk per Bar")
tp_29 = input.float(80.0,  "TP — 29 bar (pts)", group="Risk per Bar")
sl_35 = input.float(30.0,  "SL — 35 bar (pts)", group="Risk per Bar")
tp_35 = input.float(120.0, "TP — 35 bar (pts)", group="Risk per Bar")

// ─── TIME (ET) ────────────────────────────────────────────────────────────────
et_hour  = hour(time, "America/New_York")
et_min   = minute(time, "America/New_York")
h_plus_m = et_hour + et_min
min_only = et_min

in_23 = (h_plus_m >= 22 and h_plus_m <= 24) or (min_only >= 22 and min_only <= 24)
in_29 = (h_plus_m >= 28 and h_plus_m <= 30) or (min_only >= 28 and min_only <= 30)
in_35 = (h_plus_m >= 34 and h_plus_m <= 36) or (min_only >= 34 and min_only <= 36)

is_time_bar = in_23 or in_29 or in_35
time_zone   = in_23 ? "23" : in_29 ? "29" : in_35 ? "35" : ""

// ─── COOLDOWN ────────────────────────────────────────────────────────────────
var int last_signal_bar = -999
cooldown_ok = (bar_index - last_signal_bar) >= cooldown

// ─── LIQUIDITY SWEEP CHECK ───────────────────────────────────────────────────
// Prior high/low over lookback window (excluding current bar)
prior_high = ta.highest(high, lookback)[1]
prior_low  = ta.lowest(low,  lookback)[1]

// Time bar sweeps: wick touches prior level (no close required)
swept_high = is_time_bar and high >= prior_high   // bearish sweep — took out prior high
swept_low  = is_time_bar and low  <= prior_low    // bullish sweep — took out prior low

// ─── STORE TIME BAR STATE ────────────────────────────────────────────────────
// When a valid sweep time bar forms, store its high/low and which direction
var float tb_high      = na
var float tb_low       = na
var int   tb_bar       = -999
var bool  tb_bear      = false   // true = swept high → looking for close below tb_low (short)
var bool  tb_bull      = false   // true = swept low  → looking for close above tb_high (long)
var string tb_zone     = ""
var float  tb_sl       = na
var float  tb_tp       = na

if (swept_high or swept_low) and cooldown_ok
    tb_high  := high
    tb_low   := low
    tb_bar   := bar_index
    tb_bear  := swept_high
    tb_bull  := swept_low and not swept_high   // prefer bear if both (rare)
    tb_zone  := time_zone
    tb_sl    := in_23 ? sl_23 : in_29 ? sl_29 : sl_35
    tb_tp    := in_23 ? tp_23 : in_29 ? tp_29 : tp_35

// ─── CONFIRMATION ────────────────────────────────────────────────────────────
bars_since_tb  = bar_index - tb_bar
in_window      = bars_since_tb >= 1 and bars_since_tb <= confirm_bars

// Short confirmation: close below time bar low
short_confirm = in_window and tb_bear and not na(tb_low) and close < tb_low and cooldown_ok

// Long confirmation: close above time bar high
long_confirm  = in_window and tb_bull and not na(tb_high) and close > tb_high and cooldown_ok

// Fire signal and reset
if short_confirm or long_confirm
    last_signal_bar := bar_index
    tb_bar          := -999   // reset so we don't double-fire

// ─── ACTIVE TP/SL FOR CONFIRMED SIGNAL ───────────────────────────────────────
signal_sl = tb_sl
signal_tp = tb_tp

// ─── DISPLAY ─────────────────────────────────────────────────────────────────
bgcolor(show_zones and is_time_bar ? color.new(color.purple, 90) : na, title="Time Bar Zone")

// Mark time bar sweep candles (dim — not entries)
plotshape(swept_high and cooldown_ok, "TB Sweep High", shape.diamond, location.abovebar,
          color=color.new(color.orange, 50), size=size.tiny)
plotshape(swept_low and cooldown_ok,  "TB Sweep Low",  shape.diamond, location.belowbar,
          color=color.new(color.aqua,   50), size=size.tiny)

// Mark confirmed entry candles (bright)
plotshape(short_confirm, "Short Entry", shape.triangledown, location.abovebar,
          color=color.new(color.red,  0), size=size.small)
plotshape(long_confirm,  "Long Entry",  shape.triangleup,   location.belowbar,
          color=color.new(color.lime, 0), size=size.small)

// Entry labels
if short_confirm
    label.new(bar_index, high + ta.atr(14) * 0.4,
              "S" + tb_zone,
              style=label.style_label_down,
              color=color.new(color.red, 10),
              textcolor=color.white,
              size=size.tiny)

if long_confirm
    label.new(bar_index, low - ta.atr(14) * 0.4,
              "L" + tb_zone,
              style=label.style_label_up,
              color=color.new(color.lime, 10),
              textcolor=color.black,
              size=size.tiny)

// TP / SL lines from entry close
var line tp_line = na
var line sl_line = na

if long_confirm
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, close + signal_tp, bar_index + 20, close + signal_tp,
                        color=color.new(color.lime, 20), width=1, style=line.style_dashed)
    sl_line := line.new(bar_index, close - signal_sl, bar_index + 20, close - signal_sl,
                        color=color.new(color.red,  20), width=1, style=line.style_dashed)

if short_confirm
    line.delete(tp_line)
    line.delete(sl_line)
    tp_line := line.new(bar_index, close - signal_tp, bar_index + 20, close - signal_tp,
                        color=color.new(color.lime, 20), width=1, style=line.style_dashed)
    sl_line := line.new(bar_index, close + signal_sl, bar_index + 20, close + signal_sl,
                        color=color.new(color.red,  20), width=1, style=line.style_dashed)

// ─── ALERTS ───────────────────────────────────────────────────────────────────
alertcondition(long_confirm,  "27m LONG",  "27m Time Reversal LONG | Zone: " + tb_zone)
alertcondition(short_confirm, "27m SHORT", "27m Time Reversal SHORT | Zone: " + tb_zone)
