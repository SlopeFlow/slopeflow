//@version=6
indicator("PL Alert | Newsie", overlay=false, max_bars_back=1000)
fib_tol = input.float(8.0, "Tolerance pts near 100%", group="Setup")
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb  = t23 or t29 or t35
tz  = t23 ? "23" : t29 ? "29" : "35"
bc  = close > open
br  = close < open
new_sess = ta.change(time("D")) != 0
var float sess_hi = na
var float sess_lo = na
if new_sess
    sess_hi := high
    sess_lo := low
else
    sess_hi := math.max(sess_hi, high)
    sess_lo := math.min(sess_lo, low)
fr    = not na(sess_hi) ? sess_hi - sess_lo : na
f100u = not na(fr) ? sess_hi + fr : na
f100d = not na(fr) ? sess_lo - fr : na
at_100u = not na(f100u) and math.abs(high - f100u) <= fib_tol
at_100d = not na(f100d) and math.abs(low  - f100d) <= fib_tol
short_sig = tb and at_100u and bc
long_sig  = tb and at_100d and br
bgcolor(short_sig ? color.new(color.red,  80) : long_sig ? color.new(color.lime, 80) : na)
plotshape(short_sig, "PL Short Alert", shape.triangledown, location.top,    color=color.new(color.red,  0), size=size.normal)
plotshape(long_sig,  "PL Long Alert",  shape.triangleup,   location.bottom, color=color.new(color.lime, 0), size=size.normal)
alertcondition(short_sig, "PL SHORT Alert", "PL SHORT: 100% fib + time bar")
alertcondition(long_sig,  "PL LONG Alert",  "PL LONG: 100% fib + time bar")
