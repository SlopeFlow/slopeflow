//@version=6
strategy("BOS Reversal BT | Newsie", overlay=true, max_bars_back=1000, initial_capital=50000, default_qty_type=strategy.fixed, default_qty_value=1, commission_type=strategy.commission.cash_per_contract, commission_value=2.05, slippage=1)
bos_n = input.int(30, "BOS Lookback bars", group="Setup")
ml = input.float(50.0, "Min leg pts", group="Setup")
stp = input.float(30.0, "Stop pts", group="Risk")
tp = input.float(60.0, "TP pts", group="Risk")
cd = input.int(60, "Cooldown bars", group="Setup")
eh = hour(time, "America/New_York")
em = minute(time, "America/New_York")
s = eh + em
d = em - eh
t23 = ((s>=22 and s<=24) or (d>=22 and d<=24) or (em>=22 and em<=24) or (eh==2 and em>=2 and em<=4))
t29 = ((s>=28 and s<=30) or (d>=28 and d<=30) or (em>=28 and em<=30) or (eh==2 and em>=8 and em<=9))
t35 = ((s>=34 and s<=36) or (d>=34 and d<=36) or (em>=34 and em<=36) or (eh==3 and em>=4 and em<=6))
tb = t23 or t29 or t35
bc = close > open
br = close < open
prior_high = ta.highest(high, bos_n)
prior_low  = ta.lowest(low,  bos_n)
bull_bos = close > prior_high[1] and bc
bear_bos = close < prior_low[1]  and br
var string bos_dir = na
var float  bos_ext = na
var int    bos_bar = -999
var int    last_sig = -999
if bull_bos
    bos_dir := "bull"
    bos_ext := prior_low[1]
    bos_bar := bar_index
if bear_bos
    bos_dir := "bear"
    bos_ext := prior_high[1]
    bos_bar := bar_index
leg_hi = bos_dir == "bull" ? ta.highest(high, bar_index - bos_bar + 1) : bos_ext
leg_lo = bos_dir == "bear" ? ta.lowest(low,   bar_index - bos_bar + 1) : bos_ext
leg_size = not na(leg_hi) and not na(leg_lo) ? leg_hi - leg_lo : na
z40 = not na(leg_size) ? leg_lo + leg_size * 0.40 : na
z60 = not na(leg_size) ? leg_lo + leg_size * 0.60 : na
plot(not na(leg_hi) ? leg_hi : na, "Leg Hi", color=color.new(color.lime, 60), linewidth=1, style=plot.style_stepline)
plot(not na(leg_lo) ? leg_lo : na, "Leg Lo", color=color.new(color.red, 60), linewidth=1, style=plot.style_stepline)
plot(not na(z40) ? (z40+z60)/2 : na, "50%", color=color.new(color.yellow, 0), linewidth=1)
age_ok = bar_index - bos_bar > 15
cd_ok  = bar_index - last_sig > cd
in_zone_l = not na(z40) and not na(z60) and low  <= z60 and low  >= z40
in_zone_s = not na(z40) and not na(z60) and high >= z40 and high <= z60
ls = tb and bos_dir == "bull" and in_zone_l and bc and age_ok and cd_ok and not na(leg_size) and leg_size >= ml and strategy.position_size == 0
ss = tb and bos_dir == "bear" and in_zone_s and br and age_ok and cd_ok and not na(leg_size) and leg_size >= ml and strategy.position_size == 0
if ls or ss
    last_sig := bar_index
bgcolor(tb ? color.new(color.purple, 93) : na)
plotshape(ls, "L", shape.triangleup,   location.belowbar, color=color.new(color.lime, 0), size=size.small)
plotshape(ss, "S", shape.triangledown,  location.abovebar, color=color.new(color.red, 0), size=size.small)
if ls
    strategy.entry("Long", strategy.long)
    strategy.exit("LX", "Long", limit=close+tp, stop=close-stp)
if ss
    strategy.entry("Short", strategy.short)
    strategy.exit("SX", "Short", limit=close-tp, stop=close+stp)
